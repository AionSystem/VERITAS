{
  "version": 2,
  "functions": {
    "api/stp-seal.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/sync.js": {
      "maxDuration": 10,
      "memory": 1024
    },
    "api/reports.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/stp-seal",
      "dest": "/api/stp-seal.js",
      "methods": ["GET", "POST", "OPTIONS", "DELETE"]
    },
    {
      "src": "/api/stp-seal/verify",
      "dest": "/api/stp-seal.js",
      "methods": ["GET"]
    },
    {
      "src": "/api/stp-seal/verify-file",
      "dest": "/api/stp-seal.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/stp-seal/ledger",
      "dest": "/api/stp-seal.js",
      "methods": ["GET"]
    },
    {
      "src": "/api/stp-seal/delete",
      "dest": "/api/stp-seal.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/stp-seal/consent/withdraw",
      "dest": "/api/stp-seal.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/health",
      "dest": "/api/stp-seal.js",
      "methods": ["GET"]
    },
    {
      "src": "/api/sync",
      "dest": "/api/sync.js"
    },
    {
      "src": "/api/reports",
      "dest": "/api/reports.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/certify",
      "dest": "/public/aion-certify/index.html"
    },
    {
      "src": "/certify/(.*)",
      "dest": "/public/aion-certify/$1"
    },
    {
      "src": "/simulator",
      "dest": "/public/certus-ai/index.html"
    },
    {
      "src": "/simulator/(.*)",
      "dest": "/public/certus-ai/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS, DELETE" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}